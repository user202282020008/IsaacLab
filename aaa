  "content": "\"\"\"\n数据库模型定义\n包含：交易数据表、清洗日志表\n\"\"\"\nfrom datetime import datetime\nfrom sqlalchemy import create_engine, Column, Integer, String, Float, DateTime, Text, Boolean\nfrom sqlalchemy.ext.declarative import declarative_base\nfrom sqlalchemy.orm import sessionmaker\nimport os\n\nBase = declarative_base()\n\n# 数据库路径\nDB_PATH = os.path.join(os.path.dirname(__file__), 'data', 'retail.db')\nos.makedirs(os.path.dirname(DB_PATH), exist_ok=True)\n\n# 创建引擎\nengine = create_engine(f'sqlite:///{DB_PATH}', echo=False)\nSession = sessionmaker(bind=engine)\n\n\nclass CleanedTransaction(Base):\n    \"\"\"清洗后的交易数据表\"\"\"\n    __tablename__ = 'cleaned_transactions'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    transaction_id = Column(String(50), unique=True, nullable=False, index=True)\n    item_name = Column(String(200), nullable=False)\n    department = Column(String(100), nullable=False)\n    sales_volume = Column(Float, nullable=False)\n    retail_price = Column(Float, nullable=False)\n    purchase_price = Column(Float, nullable=False)\n    profit_margin = Column(Float)  # 计算字段：利润率\n    batch_id = Column(String(50))  # 批次ID\n    created_at = Column(DateTime, default=datetime.now)\n    updated_at = Column(DateTime, default=datetime.now, onupdate=datetime.now)\n\n    def to_dict(self):\n        return {\n            'id': self.id,\n            'transaction_id': self.transaction_id,\n            'item_name': self.item_name,\n            'department': self.department,\n            'sales_volume': self.sales_volume,\n            'retail_price': self.retail_price,\n            'purchase_price': self.purchase_price,\n            'profit_margin': self.profit_margin,\n            'batch_id': self.batch_id,\n            'created_at': self.created_at.strftime('%Y-%m-%d %H:%M:%S') if self.created_at else None,\n            'updated_at': self.updated_at.strftime('%Y-%m-%d %H:%M:%S') if self.updated_at else None\n        }\n\n\nclass CleaningLog(Base):\n    \"\"\"数据清洗日志表\"\"\"\n    __tablename__ = 'cleaning_logs'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    batch_id = Column(String(50), nullable=False, index=True)\n    source_file = Column(String(255))\n    total_records = Column(Integer, default=0)  # 总记录数\n    cleaned_records = Column(Integer, default=0)  # 清洗后记录数\n    duplicate_count = Column(Integer, default=0)  # 重复记录数\n    null_value_count = Column(Integer, default=0)  # 空值处理数\n    invalid_numeric_count = Column(Integer, default=0)  # 无效数值数\n    dirty_text_count = Column(Integer, default=0)  # 脏文本处理数\n    error_count = Column(Integer, default=0)  # 错误数\n    cleaning_time_seconds = Column(Float, default=0.0)  # 清洗耗时(秒)\n    status = Column(String(20), default='pending')  # pending, success, failed\n    error_message = Column(Text)\n    started_at = Column(DateTime)\n    finished_at = Column(DateTime)\n    created_at = Column(DateTime, default=datetime.now)\n\n    def to_dict(self):\n        return {\n            'id': self.id,\n            'batch_id': self.batch_id,\n            'source_file': self.source_file,\n            'total_records': self.total_records,\n            'cleaned_records': self.cleaned_records,\n            'duplicate_count': self.duplicate_count,\n            'null_value_count': self.null_value_count,\n            'invalid_numeric_count': self.invalid_numeric_count,\n            'dirty_text_count': self.dirty_text_count,\n            'error_count': self.error_count,\n            'cleaning_time_seconds': round(self.cleaning_time_seconds, 3),\n            'status': self.status,\n            'error_message': self.error_message,\n            'started_at': self.started_at.strftime('%Y-%m-%d %H:%M:%S') if self.started_at else None,\n            'finished_at': self.finished_at.strftime('%Y-%m-%d %H:%M:%S') if self.finished_at else None,\n            'created_at': self.created_at.strftime('%Y-%m-%d %H:%M:%S') if self.created_at else None\n        }\n\n\nclass CleaningDetailLog(Base):\n    \"\"\"清洗明细日志 - 记录每条异常数据\"\"\"\n    __tablename__ = 'cleaning_detail_logs'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    batch_id = Column(String(50), nullable=False, index=True)\n    transaction_id = Column(String(50))\n    field_name = Column(String(50))  # 字段名\n    original_value = Column(Text)  # 原始值\n    cleaned_value = Column(Text)  # 清洗后值\n    issue_type = Column(String(50))  # 问题类型：duplicate, null, invalid_numeric, dirty_text\n    issue_description = Column(Text)  # 问题描述\n    is_fixed = Column(Boolean, default=True)  # 是否修复\n    created_at = Column(DateTime, default=datetime.now)\n\n\ndef init_db():\n    \"\"\"初始化数据库\"\"\"\n    Base.metadata.create_all(engine)\n    return engine\n\n\ndef get_session():\n    \"\"\"获取数据库会话\"\"\"\n    return Session()\n"